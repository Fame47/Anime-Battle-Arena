const sounds = {};
const SOUND_NAMES = [
  'click','choose your fighter',
  'ready','fight','round1','round2','round3',
  'attack','defend','counter','Powerup',
  'SPready','heroSP','antiheroSP','villainSP',
  'victory','defeat','worldfight','darkfight',
