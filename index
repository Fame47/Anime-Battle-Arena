}
.damageRules b{color:#fff}

/* =========================================================
   🔵 HELP SECTION 13: PAUSE MENU
========================================================= */
.pauseOverlay{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.88);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:9999;
}
.pauseOverlay.hidden{display:none}
.pauseBox,.pauseHowBox{
