/* =========================================================
   🔵 FIREBASE ONLINE MULTIPLAYER
   Safe layer for VS Mode only. Story, Dark Tournament, and Arcade are untouched.
========================================================= */
function onlineCodeClean(v){
  return (v || '').toUpperCase().replace(/[^A-Z0-9]/g,'').slice(0,6);
}

function makeRoomCode(){
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let code = 'ABA';
  for(let i=0;i<3;i++) code += chars[Math.floor(Math.random()*chars.length)];
  return code;
}

function blankOnlinePlayer(){
  return {
    fighter:null,
    ready:false,
    hp:12,
    gems:0,
    power:false,
    choice:null,
    connected:true
  };
}

function requireFirebase(){
  if(!firebaseReady || !onlineDb){
    alert('Firebase is not connected. Make sure this file is online or your browser allows the Firebase scripts.');
    return false;
  }
  return true;
}

function createOnlineArena(){
  if(!requireFirebase()) return;
  leaveOnlineRoom(false);

  onlineRoomCode = makeRoomCode();
  onlinePlayerSlot = 'player1';
  onlineBattleStarted = false;
  onlineFinishedHandled = false;
  onlineLastRound = 0;
  onlineLastTurn = 0;

  onlineRoomRef = onlineDb.ref('rooms/' + onlineRoomCode);
  onlineRoomRef.set({
    status:'selecting',
    createdAt:firebase.database.ServerValue.TIMESTAMP,
    updatedAt:firebase.database.ServerValue.TIMESTAMP,
    host:'player1',
    turn:1,
    round:1,
    p1RoundWins:0,
    p2RoundWins:0,
    resultTurn:0,
    player1:blankOnlinePlayer(),
    player2:blankOnlinePlayer()
  });

  document.getElementById('roomCodeDisplay').textContent = onlineRoomCode;
  document.getElementById('createStatus').textContent = 'Give this code to Player 2. Choose your fighter next.';
  showVsTab('create');
  listenOnlineRoom();
  setTimeout(()=>showSelect('online'), 450);
}

function joinOnlineArena(){
  if(!requireFirebase()) return;
  const input = document.getElementById('joinRoomInput');
  const code = onlineCodeClean(input.value);
  if(!code){
    document.getElementById('joinStatus').textContent = 'Enter a room code first.';
    return;
  }

  leaveOnlineRoom(false);

  onlineRoomCode = code;
  onlinePlayerSlot = 'player2';
  onlineBattleStarted = false;
  onlineFinishedHandled = false;
  onlineLastRound = 0;
  onlineLastTurn = 0;

  onlineRoomRef = onlineDb.ref('rooms/' + onlineRoomCode);
  onlineRoomRef.once('value').then(snap=>{
    const room = snap.val();
    if(!room){
      document.getElementById('joinStatus').textContent = 'Room not found.';
      onlineRoomRef = null;
      onlineRoomCode = null;
      onlinePlayerSlot = null;
      return;
    }
    if(room.status !== 'selecting'){
      document.getElementById('joinStatus').textContent = 'That fight already started.';
      return;
    }

    onlineRoomRef.child('player2').update(blankOnlinePlayer());
    document.getElementById('joinStatus').textContent = 'Joined room ' + onlineRoomCode + '. Choose your fighter next.';
    listenOnlineRoom();
    setTimeout(()=>showSelect('online'), 450);
  }).catch(err=>{
    console.warn(err);
    document.getElementById('joinStatus').textContent = 'Could not join room.';
  });
}

function listenOnlineRoom(){
  if(!onlineRoomRef) return;
  onlineRoomRef.off();
  onlineRoomRef.on('value', snap=>{
    const room = snap.val();
    if(!room) return;
    handleOnlineRoomUpdate(room);
  });
}

function leaveOnlineRoom(removeIfHost=true){
  if(onlineRoomRef){
    try{
      if(onlinePlayerSlot) onlineRoomRef.child(onlinePlayerSlot + '/connected').set(false);
      onlineRoomRef.off();
      if(removeIfHost && onlinePlayerSlot === 'player1'){
        // Keep room cleanup simple: host leaving deletes waiting rooms only.
        onlineRoomRef.once('value').then(s=>{
          const r = s.val();
          if(r && r.status === 'selecting') onlineRoomRef.remove();
        });
      }
    }catch(e){}
  }
  onlineRoomRef = null;
  onlineRoomCode = null;
  onlinePlayerSlot = null;
  onlineBattleStarted = false;
  onlineFinishedHandled = false;
}

function onlineSelectFighter(key){
  if(!onlineRoomRef || !onlinePlayerSlot) return;
  selected = key;
  playS(characterNameSound(key));
  onlineRoomRef.child(onlinePlayerSlot).update({
    fighter:key,
    ready:true,
    hp:(fighters[key].hp || 12),
    gems:0,
    power:false,
    choice:null,
    connected:true
  });
  const hint = document.getElementById('selectHint');
  if(hint){
    hint.classList.add('onlineRoomStatus');
    hint.innerHTML = 'FIGHTER LOCKED<br>WAITING FOR OPPONENT<span class="roomCodeBig">' + onlineRoomCode + '</span>';
  }
}

function handleOnlineRoomUpdate(room){
  if(currentMode === 'online' && document.getElementById('select').classList.contains('active')){
    const p1Name = room.player1 && room.player1.fighter ? fighters[room.player1.fighter].name : 'P1 choosing...';
    const p2Name = room.player2 && room.player2.fighter ? fighters[room.player2.fighter].name : 'P2 choosing...';
    const hint = document.getElementById('selectHint');
    if(hint){
      hint.classList.add('onlineRoomStatus');
      hint.innerHTML = 'ROOM<span class="roomCodeBig">' + onlineRoomCode + '</span>' + p1Name + ' VS ' + p2Name;
    }
  }

  if(room.status === 'selecting'){
    const p1Ready = room.player1 && room.player1.ready && room.player1.fighter;
    const p2Ready = room.player2 && room.player2.ready && room.player2.fighter;
    if(p1Ready && p2Ready && onlinePlayerSlot === 'player1'){
      const p1Key = room.player1.fighter;
      const p2Key = room.player2.fighter;
      onlineRoomRef.update({
        status:'fighting',
        round:1,
        turn:1,
        p1RoundWins:0,
        p2RoundWins:0,
        resultTurn:0,
        updatedAt:firebase.database.ServerValue.TIMESTAMP,
        'player1/hp':fighters[p1Key].hp || 12,
        'player2/hp':fighters[p2Key].hp || 12,
        'player1/gems':0,
        'player2/gems':0,
        'player1/power':false,
        'player2/power':false,
        'player1/choice':null,
        'player2/choice':null
      });
    }
    return;
  }

  if(room.status === 'fighting'){
    if(!onlineBattleStarted){
      setupOnlineBattle(room);
    }else{
      renderOnlineBattle(room);
    }

    const p1Choice = room.player1 && room.player1.choice;
    const p2Choice = room.player2 && room.player2.choice;
    if(onlinePlayerSlot === 'player1' && p1Choice && p2Choice && (room.resultTurn || 0) < room.turn){
      onlineRoomRef.child('resultTurn').set(room.turn).then(()=>resolveOnlineTurn(room));
    }
  }

  if(room.status === 'finished' && !onlineFinishedHandled){
    onlineFinishedHandled = true;
    if(!onlineBattleStarted) setupOnlineBattle(room);
    const winner = room.winner === 'player1' ? P1 : P2;
    showVictoryScreen(winner, ()=>showVsMode());
  }
}

function setupOnlineBattle(room){
  currentMode = 'online';
  onlineBattleStarted = true;
  onlineLastRound = room.round || 1;
  onlineLastTurn = room.turn || 1;

  const battle = document.getElementById('battle');
  setBgWithFallback(battle, BG.vsBattle);

  stopMusic();
  showScreen('battle');
  playMusic('World Tournament Music.mp3');

  const p1Key = room.player1.fighter;
  const p2Key = room.player2.fighter;

  P1 = makePlayer(p1Key, 'left');
  P2 = makePlayer(p2Key, 'right');
  matchRound = room.round || 1;
  p1RoundWins = room.p1RoundWins || 0;
  p2RoundWins = room.p2RoundWins || 0;

  p1Name.textContent = P1.f.name;
  p2Name.textContent = P2.f.name;
  p1Portrait.src = P1.f.portrait;
  p2Portrait.src = P2.f.portrait;

  applyOnlineStats(room);
  setPose(P1,'idle');
  setPose(P2,'idle');
  buildGems();
  buildWinDots();
  buildActions();
  updateHUD();

  startRoundCallout(matchRound, ()=>{ busy = false; });
}

function applyOnlineStats(room){
  if(!P1 || !P2) return;
  P1.hp = room.player1.hp;
  P2.hp = room.player2.hp;
  P1.gems = room.player1.gems || 0;
  P2.gems = room.player2.gems || 0;
  P1.power = !!room.player1.power;
  P2.power = !!room.player2.power;
  matchRound = room.round || 1;
  p1RoundWins = room.p1RoundWins || 0;
  p2RoundWins = room.p2RoundWins || 0;
}

function renderOnlineBattle(room){
  const oldRound = onlineLastRound;
  const oldTurn = onlineLastTurn;

  applyOnlineStats(room);
  buildWinDots();
  updateHUD();

  const c1 = room.player1.choice;
  const c2 = room.player2.choice;
  const bothLocked = !!(c1 && c2);

  // IMPORTANT: Do not reveal either player's move until BOTH choices are locked.
  if(bothLocked){
    setPose(P1, poseName(c1));
    setPose(P2, poseName(c2));
    roundText.textContent = 'MOVES LOCKED!';
  }else{
    setPose(P1,'idle');
    setPose(P2,'idle');

    const myChoice = onlinePlayerSlot === 'player1' ? c1 : c2;
    const theirChoice = onlinePlayerSlot === 'player1' ? c2 : c1;

    if(myChoice && !theirChoice){
      roundText.textContent = 'MOVE LOCKED - WAITING';
    }else if(!myChoice && theirChoice){
      roundText.textContent = 'OPPONENT LOCKED - CHOOSE!';
    }else{
      roundText.textContent = '';
    }
  }

  if(room.round !== oldRound){
    onlineLastRound = room.round;
    startRoundCallout(room.round, ()=>{ busy = false; });
    return;
  }

  if(room.turn !== oldTurn){
    onlineLastTurn = room.turn;
    busy = false;
    roundText.textContent = '';
    setPose(P1,'idle');
    setPose(P2,'idle');
  }

  buildActions();
}

function chooseOnline(act){
  if(busy || !onlineRoomRef || !onlinePlayerSlot) return;

  const localPlayer = onlinePlayerSlot === 'player2' ? P2 : P1;
  if(act === 'special' && localPlayer.gems < 3){
    playS('click');
    roundText.textContent = '3 GEMS REQUIRED';
    setTimeout(()=>roundText.textContent='',700);
    return;
  }

  playS(act === 'power' ? 'Powerup' : act);
  busy = true;
  roundText.textContent = 'MOVE LOCKED - WAITING';
  // Do not show the chosen pose yet. The move reveals only after both players lock in.
  onlineRoomRef.child(onlinePlayerSlot + '/choice').set(act);
}

function calcOnlineTurn(room){
  let p1 = Object.assign({}, room.player1);
  let p2 = Object.assign({}, room.player2);
  const a = p1.choice;
  const b = p2.choice;

  if(a === 'special') p1.gems = Math.max(0,(p1.gems||0) - 3);
  if(b === 'special') p2.gems = Math.max(0,(p2.gems||0) - 3);

  if(a === 'power') p1.power = true;
  if(b === 'power') p2.power = true;

  let d1 = 0;
  let d2 = 0;

  if(!(a === 'power' && b === 'power')){
    if(a==='attack' && b==='attack'){d1=1;d2=1}
    else if(a==='defend' && b==='defend'){}
    else if(a==='counter' && b==='counter'){}
    else if(a==='counter' && b==='attack'){d2=2}
    else if(a==='attack' && b==='counter'){d1=2}
    else if(a==='defend' && b==='counter'){d2=2}
    else if(a==='counter' && b==='defend'){d1=2}
    else if(a==='attack' && b==='defend'){d2=2}
    else if(a==='defend' && b==='attack'){d1=2}
    else if(a==='special' && b==='counter'){d1=4}
    else if(a==='counter' && b==='special'){d2=4}
    else if(a==='special' && b==='special'){d1=4;d2=4}
    else if(a==='special'){d2=4}
    else if(b==='special'){d1=4}
    else if(a==='power' && b==='attack'){d1=2}
    else if(b==='power' && a==='attack'){d2=2}
  }

  if(d2 > 0 && p1.power){ d2 *= 2; p1.power = false; }
  if(d1 > 0 && p2.power){ d1 *= 2; p2.power = false; }

  if(d1 > 0) p1.gems = Math.min(3, (p1.gems||0) + 1);
  if(d2 > 0) p2.gems = Math.min(3, (p2.gems||0) + 1);

  p1.hp = Math.max(0, (p1.hp || 0) - d1);
  p2.hp = Math.max(0, (p2.hp || 0) - d2);

  return {p1,p2,d1,d2};
}

function resolveOnlineTurn(room){
  const result = calcOnlineTurn(room);

  setTimeout(()=>{
    let updates = {
      updatedAt:firebase.database.ServerValue.TIMESTAMP,
      'player1/hp':result.p1.hp,
      'player2/hp':result.p2.hp,
      'player1/gems':result.p1.gems || 0,
      'player2/gems':result.p2.gems || 0,
      'player1/power':!!result.p1.power,
      'player2/power':!!result.p2.power
    };

    let p1Wins = room.p1RoundWins || 0;
    let p2Wins = room.p2RoundWins || 0;
    let nextRound = room.round || 1;

    if(result.p1.hp <= 0 || result.p2.hp <= 0){
      if(result.p1.hp > 0) p1Wins++;
      else p2Wins++;

      if(p1Wins >= 2 || p2Wins >= 2){
        updates.status = 'finished';
        updates.winner = p1Wins >= 2 ? 'player1' : 'player2';
        updates.p1RoundWins = p1Wins;
        updates.p2RoundWins = p2Wins;
        onlineRoomRef.update(updates);
        return;
      }else{
        nextRound++;
        updates.round = nextRound;
        updates.p1RoundWins = p1Wins;
        updates.p2RoundWins = p2Wins;
        updates['player1/hp'] = fighters[room.player1.fighter].hp || 12;
        updates['player2/hp'] = fighters[room.player2.fighter].hp || 12;
        updates['player1/power'] = false;
        updates['player2/power'] = false;
        // Gems carry over between rounds.
      }
    }

    updates.turn = (room.turn || 1) + 1;
    updates['player1/choice'] = null;
    updates['player2/choice'] = null;
    onlineRoomRef.update(updates);
  }, 1200);
}

