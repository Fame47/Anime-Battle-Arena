========================================================= */
let P1, P2, busy = false;
let matchRound = 1, p1RoundWins = 0, p2RoundWins = 0;

function beginBattle(mode){
  if(mode === 'world') selected = WORLD_PLAYER;
  if(!selected) return;

  matchRound = 1;
  p1RoundWins = 0;
  p2RoundWins = 0;

  const battle = document.getElementById('battle');
  if(mode === 'dark'){
    setBgWithFallback(battle, BG.dark);
  }else if(mode === 'arcade' || mode === 'vs'){
    setBgWithFallback(battle, BG.vsBattle);
  }else{
    setBgWithFallback(battle, BG.battle);
  }

  stopMusic();
  showScreen('battle');

  if(mode === 'dark') playMusic('Dark Tournament Music.mp3');
  else playMusic('World Tournament Music.mp3');

  P1 = makePlayer(selected, 'left');
  P2 = makePlayer(getOpponentForMode(mode), 'right');

  resetBattleUI();
}

function getOpponentForMode(mode){
  if(mode === 'world'){
    return WORLD_ORDER[worldFightIndex] || 'Brakk';
  }

  if(mode === 'arcade'){
    if(arcadeOpponents.length === 0) arcadeOpponents = shuffle(Object.keys(fighters));
    return arcadeOpponents[arcadeWins] || 'Vexar';
  }

  if(mode === 'dark'){
    const keys = Object.keys(fighters);
    const options = keys.filter(k=>k !== selected);
    return options[Math.floor(Math.random()*options.length)];
  }

  return selected === 'Raizen' ? 'Vexar' : 'Raizen';
}

function makePlayer(key, side){
  const f = fighters[key];
  return {key, side, f, hp:f.hp || 12, gems:0, power:false, choice:null};
}

function resetBattleUI(){
  busy = true;

  p1Name.textContent = P1.f.name;
  p2Name.textContent = P2.f.name;
  p1Portrait.src = P1.f.portrait;
  p2Portrait.src = P2.f.portrait;

  setPose(P1,'idle');
  setPose(P2,'idle');

  buildGems();
  buildWinDots();
  buildActions();
  updateHUD();

  startRoundCallout(1, ()=>{ busy = false; });
}

function startRoundCallout(roundNumber, done){
  roundTracker.textContent = 'ROUND ' + roundNumber;
  roundText.textContent = 'ROUND ' + roundNumber;

  playS('round' + roundNumber);

  setTimeout(()=>{
    roundText.textContent = 'FIGHT!';
    playS('fight');
  }, 800);

  setTimeout(()=>{
    roundText.textContent = '';
    if(done) done();
  }, 1450);
}

function srcFor(p,pose){
  return p.f.sprites[pose][p.side];
}
function setPose(p,pose){
  const el = p.side === 'left' ? p1Sprite : p2Sprite;
  el.src = srcFor(p,pose);
}

