function showDarkNameEntry(){
  document.getElementById('darkFinalText').textContent = 'You survived ' + darkRunWins + ' fight' + (darkRunWins===1?'':'s') + '. Enter 3 initials.';
  const inp = document.getElementById('darkNameInput');
