  border-radius:20px;
  padding:30px;
  text-align:center;
  box-shadow:0 0 45px #ffd43d88;
}
.pauseBox h2,.pauseHowBox h2{
  font-size:72px;
  margin:0 0 25px;
  color:#ffd43d;
  
}
.pauseMenuBtn{
  display:block;
  width:min(440px,80vw);
  margin:14px auto;
  padding:16px 20px;
  font-size:34px;
  background:#111;
  border:2px solid #fff;
