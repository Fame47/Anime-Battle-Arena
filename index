function showWorldStory(panelNumber){
  currentStoryPanel = panelNumber;
  const storyImg = document.getElementById('storyImg');
  const placeholder = document.getElementById('storyPlaceholder');

  if(placeholder) placeholder.style.display = 'none';

  if(storyImg){
    storyImg.style.display = 'none';

    let i = 0;
    function tryStoryImage(){
      if(i >= IMG_EXTS.length){
        if(placeholder) placeholder.style.display = 'block';
        storyImg.style.display = 'none';
        showScreen('story');
        return;
      }

      const candidate = A + 'story' + panelNumber + IMG_EXTS[i];
      storyImg.onload = function(){
        if(placeholder) placeholder.style.display = 'none';
        storyImg.style.display = 'block';
        showScreen('story');
      };
      storyImg.onerror = function(){
        i++;
        tryStoryImage();
      };
      storyImg.src = candidate;
    }

    tryStoryImage();
  }else{
    showScreen('story');
  }
}

