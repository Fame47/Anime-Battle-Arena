<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Anime Battle Arena - Final Offline Study Build</title>

<style>
/* =========================================================
   🔵 BLUE 🔵 HELP SECTIONS = guide headers
   🟤 BROWN NOTES = what you should read/change
   ⚫ BLACK ⚫ CODE AREAS = the actual code underneath
   Plain HTML/CSS files cannot truly color comments inside Notepad,
   so the color coding uses emoji labels that are easy to search.
========================================================= */

/* =========================================================
   🔵 HELP SECTION 00: GLOBAL RESET
   Keeps page clean, no scroll bars, no white browser space.
========================================================= */
*{box-sizing:border-box}
html,body{
  margin:0;
  padding:0;
  width:100vw;
  height:100vh;
  overflow:hidden;
  background:#000;
  color:#fff;
  font-family:Impact,Haettenschweiler,'Arial Narrow Bold',sans-serif;
  letter-spacing:1px;
  user-select:none;
}
button{
  font-family:inherit;
  letter-spacing:1px;
  cursor:pointer;
  color:#fff;
  border:none;
  background:none;
}

/* =========================================================
   🔵 🔵 HELP SECTION 01: OUTER ARCADE FRAME / PSD TEMPLATE
   🟤 🟤 NOTE:
   The full outside frame is now ONE image exported from Photoshop.
   Update this file whenever you want to change ads/characters/frame art:

   assets/ABA_FRAME.jpg

   Keep the actual gameplay inside the transparent/open area of your PSD.
   ========================================================= */

/* ⚫ ⚫ CODE AREA: outer frame background */
#arcadeFrame{
  position:fixed;
  inset:0;
  width:100vw;
  height:100vh;
  background:#000 url('assets/ABA_FRAME.jpg') center/cover no-repeat;
  overflow:hidden;
}

/* =========================================================
   🔵 🔵 HELP SECTION 02: GAME WINDOW
   🟤 🟤 NOTE:
   This rectangle is where the playable game sits.
   If your PSD opening does not line up, adjust:
   left, top, width, height.
   Larger top = game moves down.
   Larger left = game moves right.
   ========================================================= */


/* =========================================================
   🔵 HELP SECTION 01B: CLICKABLE AD HOTSPOTS
   🟤 NOTE:
   These invisible link boxes sit on top of your PSD frame.
   Each one matches an ad space in your ABA_FRAME.jpg.

   HOW TO USE:
   1. Replace href="INSERT AD link here" with the real ad link.
   2. Example: href="https://fame47.github.io/Comic-Run/"
   3. Keep target="_blank" so the ad opens in a new tab.

   AD SPACE MAP:
   AD Space 1 = top-left horizontal banner
   AD Space 2 = top-right horizontal banner
   AD Space 3 = bottom horizontal banner
   AD Space 4 = left vertical banner
   AD Space 5 = right vertical banner

   If you want to see the clickable areas while testing, change:
   background:transparent; border:none;
   to:
   background:rgba(0,255,255,.18); border:2px solid rgba(0,255,255,.8);
========================================================= */
.adHotspot{
  position:absolute;
  display:block;
  z-index:20;
  background:transparent;
  border:none;
}

/* ⚫ CODE AREA: AD Space 1 — top-left banner */
#adSpace1{
  left:12%;
  top:3.5%;
  width:31.8%;
  height:10.6%;
}

/* ⚫ CODE AREA: AD Space 2 — top-right banner */
#adSpace2{
  left:56.2%;
  top:3.5%;
  width:31.8%;
  height:10.6%;
}

/* ⚫ CODE AREA: AD Space 3 — bottom banner */
#adSpace3{
  left:10.5%;
  top:84.5%;
  width:79%;
  height:10.5%;
}

/* ⚫ CODE AREA: AD Space 4 — left vertical banner */
#adSpace4{
  left:1.2%;
  top:17%;
  width:8.4%;
  height:66%;
}

/* ⚫ CODE AREA: AD Space 5 — right vertical banner */
#adSpace5{
  left:90.3%;
  top:17%;
  width:8.4%;
  height:66%;
}

#gameWindow{
  position:absolute;
  left:10.5%;
  top:17%;
  width:79%;
  height:66%;
  border:3px solid #d7b44a;
  overflow:hidden;
  background:#000;
  box-shadow:0 0 25px rgba(255,215,80,.35);
  z-index:5;
}

#game{
  position:absolute;
  left:50%;
  top:50%;
  width:1920px;
  height:1080px;
  transform-origin:center center;
  overflow:hidden;
  background:#000;
}

/* Every game screen fills the 1920x1080 internal game canvas */
.screen{
  position:absolute;
  inset:0;
  width:1920px;
  height:1080px;
  display:none;
  overflow:hidden;
  background-size:cover;
  background-position:center;
}
.screen.active{display:block}
.shade{position:absolute;inset:0;background:rgba(0,0,0,.34);pointer-events:none}

/* =========================================================
   🔵 HELP SECTION 03: COMMON MENU STYLES
========================================================= */
.title{
  font-size:clamp(46px,6vw,100px);
  text-align:center;
  
  margin:0;
  text-transform:uppercase;
}
.center{
  position:absolute;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
}
.panelBtn{
  display:block;
  width:min(760px,82vw);
  margin:16px auto;
  padding:18px 34px;
  font-size:clamp(28px,3.1vw,54px);
  text-transform:uppercase;
  background:linear-gradient(90deg,rgba(0,0,0,.92),rgba(25,13,40,.85));
  border:3px solid #f4c532;
  box-shadow:0 0 22px rgba(247,199,47,.4),inset 0 0 22px rgba(0,0,0,.7);
  clip-path:polygon(0 0,94% 0,100% 50%,94% 100%,0 100%);
}
.panelBtn:hover,.tabBtn:hover,.backBtn:hover,.smallToggle:hover{
  transform:scale(1.04);
  filter:brightness(1.35);
  box-shadow:0 0 28px #fff,0 0 55px #ffd43d,inset 0 0 28px #ffd43d66;
}
.panelBtn.locked{
  filter:grayscale(1) brightness(.45);
  opacity:.55;
}
.subline{
  display:block;
  font-family:Arial,sans-serif;
  font-size:18px;
  letter-spacing:0;
  color:#e6e6e6;
  margin-top:3px;
}

/* Back/Next buttons moved UP so they do not fall outside the framed game */
.backBtn,.introNext{
  position:absolute;
  font-size:30px;
  padding:12px 25px;
  border:2px solid #fff;
  background:#070707cc;
  z-index:30;
}
.backBtn{left:26px;bottom:70px}
.introNext{right:34px;bottom:70px}

.startPrompt{
  position:absolute;
  bottom:10%;
  left:50%;
  transform:translateX(-50%);
  font-size:58px;
  
  animation:pulse 1.2s infinite;
  z-index:5;
}
@keyframes pulse{50%{opacity:.45;transform:translateX(-50%) scale(1.04)}}

/* =========================================================
   🔵 HELP SECTION 04: MAIN MENU MUSIC/SFX TOGGLES
========================================================= */
.toggleRow{
  display:flex;
  gap:14px;
  justify-content:center;
  margin-top:12px;
}
.smallToggle{
  font-size:22px;
  padding:9px 18px;
  border:2px solid #f4c532;
  background:#000c;
  color:#fff;
}
.smallToggle.off{
  color:#ff4b4b;
  border-color:#ff4b4b;
}

.volumeControls{
  width:620px;
  max-width:88%;
  margin:12px auto 0;
  padding:10px 14px;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:12px;
  background:rgba(0,0,0,.45);
  border:2px solid rgba(244,197,50,.75);
}
.volumeBox{
  display:grid;
  grid-template-columns:105px 1fr 48px;
  gap:8px;
  align-items:center;
  font-family:Arial,sans-serif;
  font-size:16px;
  letter-spacing:0;
  color:#ffd43d;
}
.volumeBox input[type="range"]{
  width:100%;
  accent-color:#ffd43d;
  cursor:pointer;
}
.volumeValue{
  color:#fff;
  text-align:right;
}

/* =========================================================
   🔵 HELP SECTION 05: INTRO / ENDING SCREENS
   Images are changed by JS. The helper tries .png/.jpg/.jpeg/.webp.
========================================================= */
.introImg{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
}
.clickLayer{position:absolute;inset:0;z-index:4}


/* =========================================================
   🔵 HELP SECTION 05B: WORLD TOURNAMENT STORY PANELS
   🟤 NOTE:
   After each World Tournament win, the game can show a comic panel image.
   File names expected inside assets:
   story1.jpg, story2.jpg, story3.jpg, story4.jpg, story5.jpg, story6.jpg, story7.jpg
========================================================= */
.storyPlaceholder{
  position:absolute;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  width:70%;
  padding:40px;
  text-align:center;
  font-size:54px;
  background:rgba(0,0,0,.70);
  border:4px solid #ffd43d;
  color:#ffd43d;
  
  z-index:3;
}

/* =========================================================
   🔵 HELP SECTION 06: CHARACTER SELECT
========================================================= */
#selectTitle{
  position:absolute;
  top:32px;
  left:0;
  right:0;
}
.selectControl{
  position:absolute;
  top:150px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:24px;
  align-items:center;
  justify-content:center;
  z-index:60;
  min-width:650px;
}
.selectedName{
  min-width:300px;
  height:68px;
  display:none;
  align-items:center;
  justify-content:center;
  text-align:center;
  font-size:44px;
  color:#fff;
  
  padding:7px 22px;
  border:3px solid #f2d33e;
  background:rgba(0,0,0,.78);
}
.roster{
  position:absolute;
  left:50%;
  top:240px;
  transform:translateX(-50%);
  display:grid;
  grid-template-columns:repeat(4,220px);
  gap:24px;
}
.charTile{
  position:relative;
  width:220px;
  height:172px;
  border:4px solid #e6e6e6;
  background:#000;
  box-shadow:0 0 14px #fff5;
  overflow:hidden;
}
.charTile img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.charTile.available:hover,.charTile.selected{
  border-color:#ffdf39;
  box-shadow:0 0 25px #ffdf39,0 0 50px #ffdf3970;
}
.charTile.lockedTile img{filter:grayscale(1) brightness(.45)}
.lockedText{
  position:absolute;
  bottom:12px;
  left:0;
  right:0;
  text-align:center;
  font-size:30px;
  color:#ddd;
  
}
.startFight.disabled{
  opacity:.35;
  pointer-events:none;
}
.startFight.ready{
  animation:startReady .6s infinite alternate;
  box-shadow:0 0 22px #ffd43d,0 0 55px #ffd43d;
  color:#ffd43d;
}
@keyframes startReady{
  0%{transform:translateX(-3px) rotate(-1deg)}
  100%{transform:translateX(3px) rotate(1deg);filter:brightness(1.5)}
}
.selectHint{
  position:absolute;
  bottom:28px;
  left:0;
  right:0;
  text-align:center;
  font-family:Arial,sans-serif;
  font-size:18px;
  letter-spacing:0;
}

/* =========================================================
   🔵 HELP SECTION 07: BATTLE HUD AND FIGHTERS
========================================================= */
#battle{background-color:#000}
.hudName{
  position:absolute;
  top:55px;
  font-size:64px;
  line-height:.9;
  color:#fff;
  
  z-index:80;
}
.hudName.left{left:175px}
.hudName.right{right:175px;text-align:right}
.hudPortrait{
  position:absolute;
  top:55px;
  width:100px;
  height:100px;
  border:4px solid #fff;
  background:#000;
  object-fit:cover;
  z-index:80;
  box-shadow:0 0 14px #fff;
}
.hudPortrait.left{left:62px}
.hudPortrait.right{right:62px}
.hpBar{
  position:absolute;
  top:155px;
  height:34px;
  width:690px;
  background:rgba(0,0,0,.6);
  border:2px solid rgba(255,255,255,.55);
  z-index:76;
}
.hpBar.left{left:62px}
.hpBar.right{right:62px}
.hpFill{height:100%;width:100%;transition:.25s}
.hpFill.left{background:#8e18ff}
.hpFill.right{background:#d7a400}
.roundTracker{
  position:absolute;
  top:90px;
  left:50%;
  transform:translateX(-50%);
  z-index:85;
  font-size:50px;
  line-height:1;
  padding:16px 36px;
  color:#ffd83d;
  border:3px solid #ffd83d;
  background:rgba(0,0,0,.58);
  
}
.winDots{
  position:absolute;
  top:118px;
  z-index:82;
  display:flex;
  gap:8px;
}
.winDots.left{left:178px}
.winDots.right{right:178px}
.winDot{
  width:18px;
  height:18px;
  border-radius:50%;
  border:2px solid #fff;
  background:#111;
  box-shadow:0 0 8px #000;
}
.winDot.on{
  background:#ffd43d;
  box-shadow:0 0 18px #ffd43d;
}
.gems{
  position:absolute;
  top:205px;
  display:flex;
  gap:14px;
  z-index:82;
}
.gems.left{left:62px}
.gems.right{right:62px}
.gem{
  width:44px;
  height:44px;
  transform:rotate(45deg);
  border:3px solid #333;
  background:#050505;
  box-shadow:0 0 8px #000;
}
.gem.full{background:#fff;box-shadow:0 0 18px #fff}
.gem.purple.full{background:#8c1cff}
.gem.gold.full{background:#ffd33c}
.gem.green.full{background:#62ff1a}
.gem.red.full{background:#ff3333}

.fighter{
  position:absolute;
  top:250px;
  height:500px;
  width:auto;
  max-width:none;
  max-height:none;
  object-fit:contain;
  z-index:25;
  
  transition:opacity .12s,transform .12s;
}
.fighter.left{left:250px;color:#9d35ff}
.fighter.right{right:250px;color:#ffcf31}
.fighter.hit{animation:hit .25s}
@keyframes hit{
  25%{transform:translateX(-18px)}
  50%{transform:translateX(18px)}
  75%{transform:translateX(-10px)}
}

/* =========================================================
   🔵 HELP SECTION 08: BATTLE BUTTONS
========================================================= */
.actionBar{
  position:absolute;
  left:50%;
  top:785px;
  transform:translateX(-50%);
  display:flex;
  justify-content:center;
  align-items:center;
  gap:28px;
  height:150px;
  z-index:60;
}
.actionBtn{
  width:150px;
  height:112px;
  padding:0;
  margin:0;
  border:0;
  outline:none;
  background:transparent;
  overflow:visible;
  cursor:pointer;
  transition:transform .14s ease, filter .14s ease;
  
}
.actionBtn img{
  width:150px;
  height:112px;
  object-fit:contain;
  display:block;
  pointer-events:none;
}
.actionBtn:hover{
  transform:translateY(-12px) scale(1.14);
  
}
.actionBtn.disabled{
  filter:grayscale(1) brightness(.35);
  opacity:.45;
}

/* =========================================================
   🔵 HELP SECTION 09: BATTLE TEXT
   Smaller and closer to the round box.
========================================================= */
.roundText{
  position:absolute;
  left:50%;
  top:230px;
  transform:translateX(-50%);
  font-size:42px;
  line-height:1;
  text-align:center;
  color:#fff;
  
  max-width:900px;
  z-index:90;
  pointer-events:none;
}

/* =========================================================
   🔵 HELP SECTION 10: SPECIAL MOVE + VICTORY OVERLAYS
   These are now above EVERYTHING, including health and round bars.
========================================================= */
.spOverlay,
.victoryOverlay{
  position:absolute !important;
  inset:0 !important;
  width:100% !important;
  height:100% !important;
  background:#000 !important;
  z-index:99999 !important;
  display:none;
  align-items:center;
  justify-content:center;
  overflow:hidden !important;
  pointer-events:none;
}
.spOverlay.show,
.victoryOverlay.show{display:flex !important}
.spOverlay img,
.victoryOverlay img{
  position:absolute !important;
  inset:0 !important;
  width:100% !important;
  height:100% !important;
  object-fit:cover !important;
  z-index:100000 !important;
}
.flash{
  position:absolute;
  inset:0;
  background:#fff;
  opacity:0;
  z-index:100001;
  pointer-events:none;
}
.flash.on{animation:flash .32s}
@keyframes flash{
  0%,100%{opacity:0}
  35%{opacity:.85}
}
.spOverlay.shake img{animation:spShake .16s infinite}
@keyframes spShake{
  0%{transform:translate(0,0) scale(1.02)}
  25%{transform:translate(-14px,8px) scale(1.025)}
  50%{transform:translate(12px,-7px) scale(1.02)}
  75%{transform:translate(-8px,-10px) scale(1.025)}
  100%{transform:translate(10px,7px) scale(1.02)}
}

/* =========================================================
   🔵 HELP SECTION 11: INFO PAGES / LEADERBOARDS / CARDS
========================================================= */
.pageContent{
  position:absolute;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  width:min(1150px,88vw);
  max-height:850px;
  overflow:auto;
  padding:34px;
  background:rgba(0,0,0,.74);
  border:3px solid #f1c832;
  box-shadow:0 0 30px #000;
}
.pageContent h2{
  font-size:72px;
  margin:0 0 18px;
  text-align:center;
  
}
.pageContent p,.pageContent li{
  font-family:Arial,sans-serif;
  font-size:23px;
  line-height:1.35;
  letter-spacing:0;
}
.tabs,.vsTabs{
  display:flex;
  gap:18px;
  justify-content:center;
  flex-wrap:wrap;
  margin:18px 0;
}
.tabBtn{
  font-size:34px;
  padding:14px 26px;
  border:3px solid #f0c834;
  background:#000d;
  min-width:260px;
}
.tabPanel{display:none}
.tabPanel.active{display:block}
.leaderBox{
  border:2px solid #fff;
  padding:20px;
  background:linear-gradient(180deg,#111b,#000b);
  box-shadow:0 0 24px #7f32ff66;
}
.leaderBox h3{
  font-size:42px;
  margin:0 0 10px;
  color:#ffd43d;
}
.leaderRow{
  font-family:Arial,sans-serif;
  font-size:24px;
  padding:10px;
  border-bottom:1px solid #ffffff33;
  letter-spacing:0;
}
.cardGrid{
  display:grid;
  grid-template-columns:repeat(4,242px);
  justify-content:center;
  gap:24px;
}
.cardWrap{text-align:center}
.cardName{
  text-align:center;
  font-size:34px;
  margin-bottom:8px;
}
.cardSlot{
  width:242px;
  height:339px;
  border:4px solid #fff;
  background:#000;
  position:relative;
  overflow:hidden;
  box-shadow:0 0 26px #f1c83255;
}
.cardSlot img{
  width:100%;
  height:100%;
  object-fit:cover;
}
.cardSlot.lockedCard img{filter:grayscale(1) brightness(.3)}
.cardSlot .unlockText{
  position:absolute;
  inset:auto 0 16px 0;
  text-align:center;
  font-size:24px;
  color:#fff;
  
  background:#0009;
  padding:6px;
}
.countText{
  font-family:Arial,sans-serif;
  font-size:18px;
  letter-spacing:0;
  margin-top:8px;
}
.cardModal{
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.86);
  z-index:99998;
  display:none;
  align-items:center;
  justify-content:center;
  flex-direction:column;
}
.cardModal.show{display:flex}
.cardModal img{
  height:min(86vh,820px);
  max-width:92vw;
  object-fit:contain;
  box-shadow:0 0 45px #f1c832;
  border:4px solid #f1c832;
}
.cardModalClose{
  margin-top:14px;
  font-size:26px;
  padding:10px 24px;
  border:2px solid #fff;
  background:#000;
}

/* =========================================================
   🔵 HELP SECTION 12: HOW TO PLAY PAGE
========================================================= */
.howPage{
  top:50%;
  max-height:860px;
}
.howSimple{
