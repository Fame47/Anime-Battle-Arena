}

function buildWinDots(){
  for(const [el,wins] of [[p1Wins,p1RoundWins],[p2Wins,p2RoundWins]]){
    el.innerHTML = '';
    for(let i=0;i<2;i++){
      const d = document.createElement('div');
      d.className = 'winDot ' + (i < wins ? 'on' : '');
      el.appendChild(d);
    }
  }
  roundTracker.textContent = 'ROUND ' + matchRound;
}

function updateHUD(){
  p1Hp.style.width = (P1.hp / (P1.f.hp || 12) * 100) + '%';
  p2Hp.style.width = (P2.hp / (P2.f.hp || 12) * 100) + '%';
  buildGems();
  buildActions();
}

function buildActions(){
  actionBar.innerHTML = '';
  const actionPlayer = (currentMode === 'online' && onlinePlayerSlot === 'player2') ? P2 : P1;
  ['attack','defend','counter','power','special'].forEach(act=>{
    const b = document.createElement('button');
    b.className = 'actionBtn ' + (act === 'special' && actionPlayer && actionPlayer.gems < 3 ? 'disabled' : '');

    const im = document.createElement('img');
    im.src = actionImgs[act];
    b.appendChild(im);

    b.onclick = ()=>choose(act);
    actionBar.appendChild(b);
  });
}

/* =========================================================
   🔵 HELP SECTION JS 13: BATTLE LOGIC
========================================================= */
function choose(act){
  if(currentMode === 'online'){
    chooseOnline(act);
    return;
  }

  if(busy) return;

  if(act === 'special' && P1.gems < 3){
    playS('click');
    roundText.textContent = '3 GEMS REQUIRED';
    setTimeout(()=>roundText.textContent='',700);
    return;
  }

  playS(act === 'power' ? 'Powerup' : act);

  P1.choice = act;
  P2.choice = aiChoice();

  resolveTurn();
}

function aiChoice(){
  let opts = ['attack','defend','counter','power'];
  if(P2.gems >= 3) opts.push('special');
  return opts[Math.floor(Math.random()*opts.length)];
}

function resolveTurn(){
  busy = true;

  const a = P1.choice;
  const b = P2.choice;

  setPose(P1,poseName(a));
  setPose(P2,poseName(b));

  if(a === 'special') P1.gems -= 3;
  if(b === 'special') P2.gems -= 3;

  if(a === 'power'){ P1.power = true; roundText.textContent = 'POWER UP!'; }
  if(b === 'power'){ P2.power = true; roundText.textContent = 'ENEMY POWER UP!'; }

  let d1 = 0;
  let d2 = 0;
  let spUser = null;

  if(!(a === 'power' && b === 'power')){
    if(a==='attack' && b==='attack'){d1=1;d2=1}
    else if(a==='defend' && b==='defend'){}
    else if(a==='counter' && b==='counter'){}
    else if(a==='counter' && b==='attack'){d2=2}
    else if(a==='attack' && b==='counter'){d1=2}
    else if(a==='defend' && b==='counter'){d2=2}
    else if(a==='counter' && b==='defend'){d1=2}
    else if(a==='attack' && b==='defend'){d2=2}
    else if(a==='defend' && b==='attack'){d1=2}
    else if(a==='special' && b==='counter'){d1=4;roundText.textContent='SPECIAL COUNTERED!'}
    else if(a==='counter' && b==='special'){d2=4;roundText.textContent='SPECIAL COUNTERED!'}
    else if(a==='special' && b==='special'){d1=4;d2=4;spUser=P1}
    else if(a==='special'){d2=4;spUser=P1}
    else if(b==='special'){d1=4;spUser=P2}
    else if(a==='power' && b==='attack'){d1=2}
    else if(b==='power' && a==='attack'){d2=2}
  }

  if(d2 > 0 && P1.power){ d2 *= 2; P1.power = false; }
  if(d1 > 0 && P2.power){ d1 *= 2; P2.power = false; }

  if(d1 > 0) P1.gems = Math.min(3, P1.gems + 1);
  if(d2 > 0) P2.gems = Math.min(3, P2.gems + 1);

  const applyDamage = ()=>{
    P1.hp = Math.max(0, P1.hp - d1);
    P2.hp = Math.max(0, P2.hp - d2);

    if(d1 > 0) hitFlash(p1Sprite);
    if(d2 > 0) hitFlash(p2Sprite);

    updateHUD();

    if(P1.hp <= 0 || P2.hp <= 0){
      endBattle();
    }else{
      setTimeout(()=>{
        setPose(P1,'idle');
        setPose(P2,'idle');
        roundText.textContent = '';
        busy = false;
      },650);
    }
  };

  if(spUser && ((spUser === P1 && d2 > 0) || (spUser === P2 && d1 > 0))){
    setTimeout(()=>showSP(spUser, applyDamage), 650);
  }else{
    setTimeout(applyDamage, 800);
  }
}

function poseName(a){
  return a === 'power' ? 'power' : a === 'special' ? 'special' : a;
}

function hitFlash(el){
  el.classList.add('hit');
  setTimeout(()=>el.classList.remove('hit'),300);
  flash.classList.add('on');
  setTimeout(()=>flash.classList.remove('on'),350);
}

function showSP(p,cb){
  spImg.src = p.f.spScreen;
  spOverlay.classList.add('show');
  spOverlay.classList.add('shake');
  playS(p.f.spSound);
  setTimeout(()=>{
    spOverlay.classList.remove('show');
    spOverlay.classList.remove('shake');
    cb();
  },3000);
}

function showVictoryScreen(winner,cb){
  victoryImg.src = winner.f.victory;
  victoryOverlay.classList.add('show');
  playS('victory');
  setTimeout(()=>{
    victoryOverlay.classList.remove('show');
    if(cb) cb();
  },2200);
}

/* =========================================================
   🔵 HELP SECTION JS 14: ROUND / MATCH ENDING
========================================================= */
function endBattle(){
  busy = true;

  const roundWinner = P1.hp > 0 ? P1 : P2;

  if(roundWinner === P1) p1RoundWins++;
  else p2RoundWins++;

  buildWinDots();
  roundText.textContent = roundWinner.f.name + ' TAKES ROUND ' + matchRound + '!';

  if(p1RoundWins >= 2 || p2RoundWins >= 2){
    const matchWinner = p1RoundWins >= 2 ? P1 : P2;
    roundText.textContent = matchWinner.f.name + ' WINS MATCH!';

    if(matchWinner === P1){
      handlePlayerMatchWin(matchWinner);
    }else{
      handlePlayerMatchLoss();
    }
  }else{
    matchRound++;
    setTimeout(()=>resetRoundOnly(), 1200);
  }
}

function resetRoundOnly(){
  P1.hp = P1.f.hp || 12;
  P2.hp = P2.f.hp || 12;
  // Gems carry over to the next round if not used.
  P1.power = false;
  P2.power = false;

  setPose(P1,'idle');
  setPose(P2,'idle');

  buildGems();
  buildWinDots();
  updateHUD();

  startRoundCallout(matchRound, ()=>{ busy = false; });
}

function handlePlayerMatchWin(matchWinner){
  if(currentMode === 'world'){
    worldFightIndex++;
    if(worldFightIndex >= WORLD_ORDER.length){
      setWorldCleared();
      showVictoryScreen(matchWinner, startEnding);
    }else{
      showVictoryScreen(matchWinner, ()=>showWorldStory(worldFightIndex));
    }
    return;
  }

  if(currentMode === 'dark'){
    setWins(P1.key, getWins(P1.key) + 1);
    darkRunWins++;
    showVictoryScreen(matchWinner, ()=>beginBattle('dark'));
    return;
  }

  if(currentMode === 'arcade'){
    arcadeWins++;
    if(arcadeWins >= 8){
      showVictoryScreen(matchWinner, ()=>{
        roundText.textContent = 'ARCADE MODE CLEARED!';
        setTimeout(()=>showVsMode(),900);
      });
    }else{
      showVictoryScreen(matchWinner, ()=>beginBattle('arcade'));
    }
    return;
  }

  showVictoryScreen(matchWinner, ()=>showSelect(currentMode));
}

function handlePlayerMatchLoss(){
  playS('defeat');

  setTimeout(()=>{
    if(currentMode === 'dark'){
      showDarkNameEntry();
    }else if(currentMode === 'arcade'){
      arcadeLives--;
      if(arcadeLives > 0) showContinue('arcade', arcadeLives);
      else showScreen('main');
    }else{
      worldLives--;
      if(worldLives > 0) showContinue('world', worldLives);
      else showScreen('main');
    }
  },1600);
}

