];

let sfxOn = localStorage.getItem('ABA_sfxOn') !== 'false';
let musicOn = localStorage.getItem('ABA_musicOn') !== 'false';
let sfxVolume = parseFloat(localStorage.getItem('ABA_sfxVolume') || '0.38');
let musicVolume = parseFloat(localStorage.getItem('ABA_musicVolume') || '0.45');

SOUND_NAMES.forEach(n=>{
  sounds[n] = new Audio(soundFile(n));
  sounds[n].preload = 'auto';
  sounds[n].volume = sfxVolume; // 🟤 NOTE: controlled by SFX slider on the main menu.
});

const music = document.getElementById('music');
music.volume = musicVolume;
let audioReady = false;

function unlockAudio(){
  if(audioReady) return;
  audioReady = true;
  if(musicOn) music.play().catch(()=>{});
}
document.addEventListener('pointerdown', unlockAudio, {once:true});

function playS(n){
  if(!sfxOn) return;
  try{
    const s = sounds[n];
    if(!s) return;
    s.currentTime = 0;
    s.play().catch(()=>{});
  }catch(e){}
}

function playMusic(file){
  if(!musicOn) return;
  if(!music.src.endsWith(file)) music.src = A + file;
  music.volume = musicVolume;
  music.play().catch(()=>{});
}

function stopMusic(){
  music.pause();
  music.currentTime = 0;
}

function updateAudioButtons(){
  const mt = document.getElementById('musicToggle');
  const st = document.getElementById('sfxToggle');
  const ms = document.getElementById('musicSlider');
  const ss = document.getElementById('sfxSlider');
  const mv = document.getElementById('musicVolText');
  const sv = document.getElementById('sfxVolText');

  if(mt){
    mt.textContent = musicOn ? 'MUSIC: ON' : 'MUSIC: OFF';
    mt.classList.toggle('off', !musicOn);
  }
  if(st){
    st.textContent = sfxOn ? 'SFX: ON' : 'SFX: OFF';
    st.classList.toggle('off', !sfxOn);
  }
  if(ms){ ms.value = Math.round(musicVolume * 100); }
  if(ss){ ss.value = Math.round(sfxVolume * 100); }
  if(mv){ mv.textContent = Math.round(musicVolume * 100) + '%'; }
  if(sv){ sv.textContent = Math.round(sfxVolume * 100) + '%'; }
}

function setMusicVolume(value){
  musicVolume = Math.max(0, Math.min(1, Number(value) / 100));
  localStorage.setItem('ABA_musicVolume', String(musicVolume));
  music.volume = musicVolume;
  updateAudioButtons();
}
function setSfxVolume(value){
  sfxVolume = Math.max(0, Math.min(1, Number(value) / 100));
  localStorage.setItem('ABA_sfxVolume', String(sfxVolume));
  Object.values(sounds).forEach(s=>{ s.volume = sfxVolume; });
  updateAudioButtons();
}

function toggleMusic(){
  musicOn = !musicOn;
  localStorage.setItem('ABA_musicOn', musicOn);
  updateAudioButtons();
  if(musicOn) playMusic('Main Menu Music.mp3'); else stopMusic();
}
function toggleSfx(){
  sfxOn = !sfxOn;
  localStorage.setItem('ABA_sfxOn', sfxOn);
  updateAudioButtons();
  playS('click');
}

