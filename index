function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

/* =========================================================
   🔵 HELP SECTION JS 17: GAME WINDOW SCALING
   This keeps the 1920x1080 game scaled inside the game box.
========================================================= */
(function(){
  const W = 1920;
  const H = 1080;

  function fitGameInsideWindow(){
    const gameWindow = document.getElementById('gameWindow');
    const game = document.getElementById('game');
    if(!gameWindow || !game) return;

    const box = gameWindow.getBoundingClientRect();
    const scale = Math.min(box.width / W, box.height / H);

    game.style.transform = 'translate(-50%, -50%) scale(' + scale + ')';
  }

  window.addEventListener('resize', fitGameInsideWindow);
  window.addEventListener('orientationchange', fitGameInsideWindow);
  document.addEventListener('DOMContentLoaded', fitGameInsideWindow);
  setTimeout(fitGameInsideWindow, 50);
  setTimeout(fitGameInsideWindow, 250);
  setTimeout(fitGameInsideWindow, 1000);
})();

